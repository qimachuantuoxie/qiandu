/**
 * йҚҘеү§еў–йҸҚз…ҺзҙЎ
 */
export enum ImageFormat {
  /** JPEGйҸҚз…ҺзҙЎ */
  JPEG = 'jpeg',
  /** PNGйҸҚз…ҺзҙЎ */
  PNG = 'png',
  /** WEBPйҸҚз…ҺзҙЎ */
  WEBP = 'webp',
  /** BMPйҸҚз…ҺзҙЎ */
  BMP = 'bmp',
  /** GIFйҸҚз…ҺзҙЎ */
  GIF = 'gif'
}

/**
 * йҚҘеү§еў–з’җг„©еҷә
 */
export enum ImageQuality {
  /** жөЈеәӨе·қй–І?*/
  LOW = 30,
  /** ж¶“о… з“‘з’җг„©еҷә */
  MEDIUM = 60,
  /** жҘӮжЁҝе·қй–І?*/
  HIGH = 80,
  /** йҸҲвӮ¬жҘӮжЁҝе·қй–І?*/
  MAXIMUM = 95
}

/**
 * йҚҘеү§еў–зјӮв•Ӯж–ҒеҰҜвҖізҙЎ
 */
export enum ImageScaleMode {
  /** й–«еӮҡз°Ій”ӣе ңз№ҡйҺёдҪ№зҳ®жёҡе¬¶зҙҡ */
  FIT = 'fit',
  /** жҝүоӮўеҺ–й”ӣе Јо—ҶйҚ“оҒҺзҙҡ */
  FILL = 'fill',
  /** йҺ·еӨүеҮ  */
  STRETCH = 'stretch'
}

/**
 * йҚҘеү§еў–йҸғе¬ӯжөҶз‘ҷжҺ‘е®і
 */
export enum ImageRotation {
  /** 0жҗҙ?*/
  ROTATION_0 = 0,
  /** 90жҗҙ?*/
  ROTATION_90 = 90,
  /** 180жҗҙ?*/
  ROTATION_180 = 180,
  /** 270жҗҙ?*/
  ROTATION_270 = 270
}

/**
 * йҚҘеү§еў–з‘ҒдҪёеЈҖйҚ–е“„з…ҷ
 */
export interface ImageCropRegion {
  /** XйҚ§ж„ӯзҲЈ */
