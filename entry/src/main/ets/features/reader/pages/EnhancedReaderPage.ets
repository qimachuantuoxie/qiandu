  @Builder
  buildBottomBar() {
    Column({ space: 16 }) {
      // жқ©ж¶ҳе®ійҸүвҖІз¬ҢзјҲе©ҡпҝҪ?
      Row({ space: 16 }) {
        A11yButton({
          text: 'ж¶“е©Ғз«ҙй”ҹ?,
          btnType: 'secondary',
          onClickCallback: () => this.previousChapter()
        })

        Column() {
          Slider({
            value: this.progress,
            min: 0,
            max: 100
          })
            .layoutWeight(1)
            .height(40)
            .onChange((value: number) => {
              const chapterIndex = Math.floor((value / 100) * (this.chapters.length - 1));
              this.goToChapter(chapterIndex);
            })
          Text(`${this.progress}%`)
            .fontSize(12)
            .fontColor(this.isDarkMode ? '#999' : '#666')
        }
        .layoutWeight(1)

        A11yButton({
          text: 'ж¶“е¬©з«ҙй”ҹ?,
          btnType: 'secondary',
          onClickCallback: () => this.nextChapter()
        })
      }
      .width('100%')

      // з’Ғеү§з–ҶйҺёеӨҗжҢі?
      Row({ space: 24 }) {
        // зҖӣжӨҫз¶Ӣжҫ¶Сғзҡ¬з’ӢеҶӯеҰӯ
        A11yButton({
          text: 'A-',
          onClickCallback: () => {
            this.fontSize = Math.max(this.fontSize - 2, 12);
            preferenceManager.setReadSettings({
              fontSize: this.fontSize,
              lineHeight: this.lineHeight,
              isDarkMode: this.isDarkMode
            });
          }
        })
        A11yButton({
          text: 'A+',
          onClickCallback: () => {
            this.fontSize = Math.min(this.fontSize + 2, 30);
            preferenceManager.setReadSettings({
              fontSize: this.fontSize,
              lineHeight: this.lineHeight,
              isDarkMode: this.isDarkMode
            });
          }
        })

        // TTS йҸҲжҘ„оҮ°йҺёеӨҗжҢій”ӣе ңеЁҮйҗўвҲҹovelPlayerйҚ’е—ӣгҖүйҸҲжҘ„оҮ°пҝҪ?
        A11yButton({
          text: this.isTTSPlaying ? 'пҝҪ?йҚӢж»„пҝҪ? : 'йҰғж”° йҸҲжҘ„пҝҪ?,
          onClickCallback: () => this.toggleNovelTTS()
        })

        // жҫ¶ж»ҲжЈҝеҰҜвҖізҙЎйҚ’еӣЁпҝҪ?
        A11yButton({
          text: this.isDarkMode ? 'йҲҪвӮ¬?йҸғгғ©пҝҪ? : 'moon_fill жҫ¶ж»ҲпҝҪ?,
          onClickCallback: () => {
            this.isDarkMode = !this.isDarkMode;
            preferenceManager.setReadSettings({
              fontSize: this.fontSize,
              lineHeight: this.lineHeight,
              isDarkMode: this.isDarkMode
            });
          }
        })

        // й‘іеұҫж«ҷй—Ҡе……з®°
        A11yButton({
          text: this.isAudioPlaying ? 'йҰғе№Қ йҸҶеӮҡпҝҪ? : 'йҰғе№Қ й—Ҡе……пҝҪ?,
          onClickCallback: () => {
            if (this.showAudioPanel) {
              this.showAudioPanel = !this.showAudioPanel;
            } else {
              this.pickAndPlayAudio();
            }
          }
        })

        // AI й—ғе‘°пҝҪ?
        A11yButton({
          text: 'AI й—ғе‘°пҝҪ?,
          onClickCallback: () => {
            this.showAIPanel = !this.showAIPanel;
            if (this.showAIPanel && !this.aiSummaryText && !this.aiTranslationText) {
              this.requestAISummary();
            }
          }
        })
      }
      .justifyContent(FlexAlign.Center)
      .width('100%')
    }
    .padding(Spacing.xxl)
    .width('100%')
    .backgroundColor(this.isDarkMode ? '#2C2C2E' : '#FFFFFF')
    .borderRadius({ topLeft: 16, topRight: 16 })
  }

