              .fontColor(this.isDarkMode ? '#FFFFFF' : '#333333')
          }
          .width(48)
          .height(48)
          .backgroundColor(this.isDarkMode ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.05)')
          .borderRadius(BorderRadius.xl)
          .justifyContent(FlexAlign.Center)
          .onClick(() => this.pickAndPlayAudio())
        }
        .width('100%')
        .justifyContent(FlexAlign.Center)
      }
      .width('100%')
      .padding(20)
      .backgroundColor(this.isDarkMode ? '#2C2C2E' : '#FFFFFF')
      .borderRadius({ topLeft: 16, topRight: 16 })
    }
    .width('100%')
    .height('100%')
  }

  @Builder
  AIPanel() {
    Column() {
      // йҚ—е©ҮвӮ¬еҝ”ж§‘й‘іеұҫж«ҷй–¬оҶҫпҝҪ?
      Row()
        .width('100%')
        .layoutWeight(1)
        .backgroundColor('rgba(0,0,0,0.3)')
        .onClick(() => this.closeAIPanel())

      // AI й—ҲгҲЎпҝҪ?
      Column({ space: 12 }) {
        // йҸҚеӣ¬о•Ҫй”ҹ?
        Row({ space: 8 }) {
          Text('AI й—ғе‘°оҮ°йҚ”в•Ӯеўң')
            .fontSize(14)
            .fontWeight(FontWeight.Medium)
            .fontColor(this.isDarkMode ? '#FFFFFF' : '#333333')

          Blank()

          Text('пҝҪ?)
            .fontSize(18)
            .fontColor(this.isDarkMode ? '#999999' : '#666666')
            .width(32)
            .height(32)
            .textAlign(TextAlign.Center)
            .onClick(() => this.closeAIPanel())
        }
        .width('100%')

        // Tab йҚ’еӣЁпҝҪ?
        Row({ space: 12 }) {
          // йҺҪжЁҝоӣҰйҺёеӨҗжҢі
          Text('йҰғж‘‘ йҺҪжЁҝпҝҪ?)
            .fontSize(12)
            .fontColor(this.aiActiveTab === 0 ? '#FFFFFF' : this.isDarkMode ? '#AAAAAA' : '#666666')
            .padding({ left: 12, right: 12, top: 6, bottom: 6 })
            .backgroundColor(this.aiActiveTab === 0 ? '#007DFF' : this.isDarkMode ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.05)')
            .borderRadius(BorderRadius.lg)
            .onClick(() => {
              this.aiActiveTab = 0;
              if (!this.aiSummaryText) {
                this.requestAISummary();
              }
            })

          // зјҲжҳҸзҳ§йҺёеӨҗжҢі
          Text('йҰғеҜӘ зјҲжҳҸпҝҪ?)
            .fontSize(12)
            .fontColor(this.aiActiveTab === 1 ? '#FFFFFF' : this.isDarkMode ? '#AAAAAA' : '#666666')
            .padding({ left: 12, right: 12, top: 6, bottom: 6 })
            .backgroundColor(this.aiActiveTab === 1 ? '#007DFF' : this.isDarkMode ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.05)')
            .borderRadius(BorderRadius.lg)
            .onClick(() => {
              this.aiActiveTab = 1;
              if (!this.aiTranslationText) {
                this.requestAITranslation();
              }
            })
        }
        .width('100%')

        // йҚҗе‘ӯоҶҗй”ҹ?
        Scroll() {
          if (this.isAIProcessing) {
            Column({ space: 12 }) {
              LoadingProgress()
                .width(32)
                .height(32)
                .color('#007DFF')

              Text('AI жҫ¶еӢӯжӮҠй”ҹ?..')
                .fontSize(13)
                .fontColor(this.isDarkMode ? '#AAAAAA' : '#888888')
            }
            .width('100%')
            .padding(40)
            .justifyContent(FlexAlign.Center)
          } else {
            Column({ space: 12 }) {
              // йҺҪжЁҝоӣҰйҚҗе‘ӯоҶҗ
              if (this.aiActiveTab === 0) {
                Text(this.aiSummaryText || 'йҗҗз‘°еҡ®йҺҪжЁҝоӣҰйҺёеӨҗжҢійҗўзҶёеһҡйҚҗе‘ӯоҶҗйҺҪжЁҝоӣҰ')
                  .fontSize(13)
                  .fontColor(this.isDarkMode ? '#CCCCCC' : '#333333')
                  .lineHeight(20)
              } else {
                Text(this.aiTranslationText || 'йҗҗз‘°еҡ®зјҲжҳҸзҳ§йҺёеӨҗжҢізјҲжҳҸзҳ§иӨ°ж’іеў з»”зҠәеҰӯ')
                  .fontSize(13)
                  .fontColor(this.isDarkMode ? '#CCCCCC' : '#333333')
                  .lineHeight(20)
              }
            }
            .width('100%')
            .padding(4)
          }
        }
        .layoutWeight(1)
        .width('100%')
      }
      .width('100%')
      .height(320)
      .padding(20)
      .backgroundColor(this.isDarkMode ? '#2C2C2E' : '#FFFFFF')
      .borderRadius({ topLeft: 16, topRight: 16 })
    }
    .width('100%')
    .height('100%')
  }
}

