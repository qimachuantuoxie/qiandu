/**
 * FeaturesPage ViewModel - V2й–»жҘҖзүҠе©Җ?
 */
import { preferenceManager } from '../utils/PreferenceManager';
import { fontScaleManager } from '../../../common/utils/FontScaleManager';
import { appTheme, themeManager, AppColors } from '../../../common/constants/AppTheme';

export interface FeatureItem {
  id: string;
  name: string;
  description: string;
  icon: string;
  enabled: boolean;
  titleKey?: string;
  descKey?: string;
  statusKey?: string;
  tags?: string[];
}

@ObservedV2
export class FeaturesViewModel {
  @Trace features: FeatureItem[] = [];
  @Trace isDarkMode: boolean = false;
  @Trace fontScale: number = 1.0;
  @Trace currentColors: AppColors = themeManager.getColors();

  async init(): Promise<void> {
    this.isDarkMode = appTheme.isDarkMode();
    this.fontScale = await fontScaleManager.getFontScale();
    this.currentColors = themeManager.getColors();
    this.loadFeatures();
  }

loadFeatures(): void {
    this.features = [
      { id: 'online_book', name: 'йҚҰг„§еҡҺж¶”п№Җз°ө', description: 'йҚҰг„§еҡҺйҺјж»…еӮЁйҚңеІ„ж§„з’ҮиҜІжөҳж¶”?, icon: 'book', enabled: true },
      { id: 'book_source', name: 'ж¶”пёҪз°®з» пј„жӮҠ', description: 'з» пј„жӮҠй—ғе‘°оҮ°е©§ж„¬жӢ°з‘ҷеӢ«еһҜ', icon: 'source', enabled: true },
      { id: 'folder_scan', name: 'йҸӮеӣҰж¬ўжҫ¶и§„еЈӮйҺ»?, description: 'йҺөоӮЈејҝйҸҲо„Җж№ҙйҚҘеҸҘеҠҹйҸӮеӣҰж¬ў', icon: 'folder', enabled: true },
      { id: 'reading_stats', name: 'й—ғе‘°оҮ°зјҒзҶ»о…ё', description: 'йҸҢгғ§ж№…й—ғе‘°оҮ°йҸҒзүҲеөҒзјҒзҶ»о…ё', icon: 'stats', enabled: true },
      { id: 'todo', name: 'еҜ°е‘ӯе§ҷжөңе¬®гҖҚ', description: 'з» пј„жӮҠй—ғе‘°оҮ°з’ҒвҖіеһқ', icon: 'todo', enabled: true },
      { id: 'notes', name: 'з»—ж—ҮоҶҮз» пј„жӮҠ', description: 'з» пј„жӮҠйҚңеұҪоҮұйҚ‘иҷ№з‘Әз’Ғ?, icon: 'notes', enabled: true },
      { id: 'bookmarks', name: 'ж¶”пёҫо„·з» пј„жӮҠ', description: 'з» пј„жӮҠж¶”пёҫзқ„ж¶”пёҫо„·', icon: 'bookmark', enabled: true },
      { id: 'reward', name: 'з’§зӮІе§ӘйҸҖоҲӣеҜ”', description: 'йҸҖоҲӣеҜ”еҜ®вӮ¬йҚҷжҲЈвӮ¬?, icon: 'support', enabled: true }
    ];
  }

  toggleFeature(featureId: string): void {
    const newFeatures: FeatureItem[] = [];
    for (let i = 0; i < this.features.length; i++) {
      const f = this.features[i];
      if (f.id === featureId) {
        newFeatures.push({
          id: f.id,
          name: f.name,
          description: f.description,
          icon: f.icon,
          enabled: !f.enabled,
          titleKey: f.titleKey,
          descKey: f.descKey,
          statusKey: f.statusKey,
          tags: f.tags
        });
      } else {
        newFeatures.push(f);
      }
    }
    this.features = newFeatures;
  }

  saveFeatures(): void {
    const enabledIds: string[] = [];
    for (let i = 0; i < this.features.length; i++) {
      if (this.features[i].enabled) {
        enabledIds.push(this.features[i].id);
      }
    }
    preferenceManager.setString('enabled_features', enabledIds.join(','));
  }
}

export const featuresViewModel = new FeaturesViewModel();
