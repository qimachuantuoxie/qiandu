import { logger } from '../../utils/Logger';
/**
 * й—ғе‘°пҝҪз’Ғеү§з–Ҷз» пј„жӮҠйҚЈ?
 * з» пј„жӮҠй—ғе‘°пҝҪйҚЈг„§жөүйҚҸеҙҮж®‘з’Ғеү§з–Ҷй”ӣе қз“§жөЈж’ұвӮ¬дҪ·еҜҢжЈ°жЁёвӮ¬дҪәзӮ•жӨӨз”өз“‘й”ӣ?
 */

import { basePreferenceManager } from './BasePreferenceManager';
import { ReadSettings, ReadTheme, PageTurnMode } from '../models/CoreBookModel';

const DEFAULT_READER_SETTINGS: ReadSettings = {
  fontSize: 18,
  lineSpacing: 1.6,
  theme: ReadTheme.LIGHT,
  brightness: 100,
  screenOrientation: 0,
  pageTurnMode: PageTurnMode.SIMULATION,
  fontFamily: 'system',
  paragraphSpacing: 0,
  letterSpacing: 0,
  textIndent: 0
};

/**
 * й—ғе‘°пҝҪз’Ғеү§з–Ҷз» пј„жӮҠйҚЈ?
 */
export class ReadingSettingsManager {
  /**
   * ж·ҮжҝҶз“Ёй—ғе‘°пҝҪз’Ғеү§з–Ҷ
   */
  setReadSettings(settings: ReadSettings): void {
    try {
      basePreferenceManager.setString('read_settings', JSON.stringify(settings));
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Save settings failed:', message);
    }
  }

  /**
   * й‘ҫеі°еҪҮй—ғе‘°пҝҪз’Ғеү§з–Ҷ
   */
  getReadSettings(): ReadSettings {
    try {
      const settingsStr = basePreferenceManager.getString('read_settings', '');
      if (settingsStr) {
        const settings = JSON.parse(settingsStr) as ReadSettings;
        return settings;
      }
      return DEFAULT_READER_SETTINGS;
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Load settings failed:', message);
      return DEFAULT_READER_SETTINGS;
    }
  }

  /**
   * ж·ҮжҝҶз“Ёж¶“е©ҡпҝҪ
   */
  setTheme(theme: ReadTheme): void {
    try {
      basePreferenceManager.setString('theme', theme.toString());
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Save theme failed:', message);
    }
  }

  /**
   * й‘ҫеі°еҪҮж¶“е©ҡпҝҪ
   */
  getTheme(): ReadTheme {
    try {
      const theme = basePreferenceManager.getString('theme', ReadTheme.LIGHT.toString()) as ReadTheme;
      const validThemes: ReadTheme[] = [ReadTheme.LIGHT, ReadTheme.SEPIA, ReadTheme.DARK, ReadTheme.AUTO];
      return validThemes.indexOf(theme) !== -1 ? theme : ReadTheme.LIGHT;
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Load theme failed:', message);
      logger.error('[ReadingSettings] Load theme failed:', err.message);
      return ReadTheme.LIGHT;
    }
  }

  /**
   * ж·ҮжҝҶз“ЁзјҲе©ҡгҖүеҰҜвҖізҙЎ
   */
  setPageTurnMode(mode: PageTurnMode): void {
    try {
      basePreferenceManager.setString('page_turn_mode', mode.toString());
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Save page turn mode failed:', message);
      logger.error('[ReadingSettings] Save page turn mode failed:', err.message);
    }
  }

  /**
   * й‘ҫеі°еҪҮзјҲе©ҡгҖүеҰҜвҖізҙЎ
   */
  getPageTurnMode(): PageTurnMode {
    try {
      const mode = basePreferenceManager.getString('page_turn_mode', PageTurnMode.SIMULATION.toString()) as PageTurnMode;
      const validModes: PageTurnMode[] = [PageTurnMode.SCROLL, PageTurnMode.COVER, PageTurnMode.SIMULATION, PageTurnMode.SLIDE, PageTurnMode.NONE];
      return validModes.indexOf(mode) !== -1 ? mode : PageTurnMode.SIMULATION;
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Load page turn mode failed:', message);
      logger.error('[ReadingSettings] Load page turn mode failed:', err.message);
      return PageTurnMode.SIMULATION;
    }
  }

  /**
   * ж·ҮжҝҶз“ЁзҖӣжӨҫз¶Ӣжҫ¶Сғзҡ¬
   */
  setFontSize(fontSize: number): void {
    try {
      basePreferenceManager.setString('font_size', fontSize.toString());
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Save font size failed:', message);
      logger.error('[ReadingSettings] Save font size failed:', err.message);
    }
  }

  /**
   * й‘ҫеі°еҪҮзҖӣжӨҫз¶Ӣжҫ¶Сғзҡ¬
   */
  getFontSize(): number {
    try {
      const size = basePreferenceManager.getString('font_size', '18');
      return parseInt(size, 10) || 18;
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Load font size failed:', message);
      logger.error('[ReadingSettings] Load font size failed:', err.message);
      return 18;
    }
  }

  /**
   * ж·ҮжҝҶз“ЁзҖӣжӨҫз¶ӢзјӮв•Ӯж–Ғ
   */
  setFontScale(scale: number): void {
    try {
      basePreferenceManager.setString('font_scale', scale.toString());
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Save font scale failed:', message);
      logger.error('[ReadingSettings] Save font scale failed:', err.message);
    }
  }

  /**
   * й‘ҫеі°еҪҮзҖӣжӨҫз¶ӢзјӮв•Ӯж–Ғ
   */
  getFontScale(): number {
    try {
      const scale = basePreferenceManager.getString('font_scale', '1.0');
      return parseFloat(scale) || 1.0;
    } catch (error) {
      const err = error as Error;
      const message = error instanceof Error ? error.message : String(error);
      logger.error('[ReadingSettings] Load font scale failed:', message);
      logger.error('[ReadingSettings] Load font scale failed:', err.message);
      return 1.0;
    }
  }
}

export const readingSettingsManager = new ReadingSettingsManager();
export default readingSettingsManager;

